rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    // Check if user is admin based on the 'users' collection role
    function isAdmin() { 
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'photoURL', 'createdAt', 'displayName']) &&
             data.role in ['admin', 'member'];
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['amount', 'category', 'description', 'userId', 'userName', 'date', 'type']) &&
             data.amount is number && data.amount > 0 &&
             data.userId == request.auth.uid &&
             data.type in ['income', 'expense'];
    }

    function isValidGrocery(data) {
      return data.keys().hasAll(['name', 'status']) &&
             data.name is string && data.name.size() > 0 &&
             data.status in ['pending', 'purchased'];
    }

    function isValidReimbursement(data) {
      return data.keys().hasAll(['amount', 'description', 'userId', 'userName', 'date', 'status']) &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn(); // Allow listing users for assignment dropdowns
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /transactions/{transactionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /laundry_batches/{id} {
      allow read, write: if isSignedIn();
    }

    match /groceries/{groceryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /reimbursements/{reimbursementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /events/{eventId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /health_logs/{logId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /maintenance/{logId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /relatives/{id} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /dining/{id} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /notifications/{id} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /metadata/wallet {
      allow read, write: if isSignedIn();
    }

    match /metadata/utilities {
      allow read, write: if isSignedIn();
    }

    match /metadata/dashboard {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /milk_log/{id} {
      allow read, write: if isSignedIn();
    }
  }
}
