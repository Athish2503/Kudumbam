rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Helpers (Pillar 2) ---

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'photoURL', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['admin', 'member'] &&
             data.photoURL is string && data.photoURL.size() <= 500;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['amount', 'category', 'description', 'userId', 'userName', 'date', 'type']) &&
             data.keys().size() >= 7 &&
             data.amount is number && data.amount > 0 &&
             data.category is string && data.category.size() <= 50 &&
             data.description is string && data.description.size() <= 500 &&
             data.userId == request.auth.uid &&
             data.type in ['income', 'expense'];
    }

    function isValidGrocery(data) {
      return data.keys().hasAll(['name', 'quantity', 'unit', 'category', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.quantity is number &&
             data.unit is string && data.unit.size() <= 20 &&
             data.status in ['pending', 'purchased'];
    }

    function isValidReimbursement(data) {
      return data.keys().hasAll(['amount', 'description', 'userId', 'userName', 'date', 'status']) &&
             data.amount is number && data.amount > 0 &&
             data.description is string && data.description.size() <= 1000 &&
             data.userId == request.auth.uid &&
             data.status == 'pending';
    }

    // --- Collection Matches ---

    // 1. Admins (System collection)
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console or special triggers
    }

    // 2. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().role == 'member';
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL']) && incoming().name is string) ||
        isAdmin()
      );
    }

    // 3. Transactions Collection
    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow update, delete: if isAdmin();
    }

    // 4. Groceries Collection
    match /groceries/{groceryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidGrocery(incoming());
      allow update: if isSignedIn() && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // 5. Reimbursements Collection
    match /reimbursements/{reimbursementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidReimbursement(incoming());
      allow update: if isSignedIn() && (
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        (request.auth.uid == existing().userId && existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'description']))
      );
      allow delete: if isAdmin() || (request.auth.uid == existing().userId && existing().status == 'pending');
    }

    // 6. Metadata/Wallet
    match /metadata/wallet {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // In this app, anyone can update balance via transaction. 
                                   // Better to use existsAfter for atomicity but keeping it simple for now.
    }
  }
}
